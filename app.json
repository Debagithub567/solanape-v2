{
  "expo": {
    "name": "Solanape",
    "slug": "solanape",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "solanape",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A12"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0A12"
      },
      "package": "com.deba.solanape"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deba.solanape"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Solanape to access your camera to scan QR codes for payments."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}